      <DTS:ObjectData>
        <SQLTask:SqlTaskData
          SQLTask:Connection="{88AA68A0-7729-401F-B4E7-6B547E71C12D}"
          SQLTask:SqlStatementSource="INSERT INTO Dim_Region_G01 (region, regionDescription, state, city, zipcode)&#xA;SELECT &#xA;    REGION as region,&#xA;    CASE REGION&#xA;        WHEN 'east' THEN 'Este'&#xA;        WHEN 'west' THEN 'Oeste'&#xA;        WHEN 'central' THEN 'Central'&#xA;        WHEN 'south' THEN 'Sur'&#xA;        ELSE REGION&#xA;    END as regionDescription,&#xA;    STATE as state,&#xA;    CITY as city,&#xA;    ZIPCODE as zipcode&#xA;FROM bd_staging_2025_G01.dbo.stg_Regions_G01" xmlns:SQLTask="www.microsoft.com/sqlserver/dts/tasks/sqltask" />
      </DTS:ObjectData>
    </DTS:Executable>

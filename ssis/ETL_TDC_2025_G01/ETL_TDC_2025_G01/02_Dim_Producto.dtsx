    <DTS:Executable
      DTS:refId="Package\Load Products DATAWAREHOUSE"
      DTS:CreationName="Microsoft.ExecuteSQLTask"
      DTS:Description="Execute SQL Task"
      DTS:DTSID="{94b274cd-9af8-40c5-a31d-699087c9bfcf}"
      DTS:ExecutableType="Microsoft.ExecuteSQLTask"
      DTS:LocaleID="-1"
      DTS:ObjectName="Load Products DATAWAREHOUSE"
      DTS:TaskContact="Execute SQL Task; Microsoft Corporation; SQL Server 2025; © 2025 Microsoft Corporation; All Rights Reserved;http://www.microsoft.com/sql/support/default.asp;1"
      DTS:ThreadHint="0">
      <DTS:Variables />
      <DTS:ObjectData>
        <SQLTask:SqlTaskData
          SQLTask:Connection="{88AA68A0-7729-401F-B4E7-6B547E71C12D}"
          SQLTask:SqlStatementSource="INSERT INTO Dim_Producto_G01 (productId, productName, category, package, packageType, packageSizeMl, packageSizeLiters, isDiet, isCan, isBottle)&#xA;SELECT &#xA;    CAST(CAST(PRODUCT_ID AS INT) AS VARCHAR) as productId,  -- normaliza '01' -&gt; '1'&#xA;    DETAIL as productName,&#xA;    CASE &#xA;        WHEN UPPER(DETAIL) LIKE '%COLA%' THEN 'Cola'&#xA;        WHEN UPPER(DETAIL) LIKE '%BEER%' OR UPPER(DETAIL) LIKE '%CERVEZA%' THEN 'Beer'&#xA;        WHEN UPPER(DETAIL) LIKE '%SODA%' THEN 'Soda'&#xA;        WHEN UPPER(DETAIL) LIKE '%JUICE%' OR UPPER(DETAIL) LIKE '%JUGO%' THEN 'Juice'&#xA;        WHEN UPPER(DETAIL) LIKE '%ENERGY%' OR UPPER(DETAIL) LIKE '%ENERGIZANTE%' THEN 'Energy Drink'&#xA;        ELSE 'Other'&#xA;    END as category,&#xA;    PACKAGE as package,&#xA;    CASE &#xA;        WHEN UPPER(PACKAGE) LIKE '%LATA%' OR UPPER(PACKAGE) LIKE '%CAN%' THEN 'Can'&#xA;        WHEN UPPER(PACKAGE) LIKE '%BOTELLA%' OR UPPER(PACKAGE) LIKE '%BOTTLE%' THEN 'Bottle'&#xA;        WHEN PACKAGE LIKE '%1 Liter%' OR PACKAGE LIKE '%2 Liter%' THEN 'Bottle'  -- botellas sin nombre explícito&#xA;        ELSE 'Other'&#xA;    END as packageType,&#xA;    CASE &#xA;        WHEN PACKAGE LIKE '%2 litro%' OR PACKAGE LIKE '%2L%' OR PACKAGE LIKE '%2 Liter%' THEN 2000&#xA;        WHEN PACKAGE LIKE '%1 litro%' OR PACKAGE LIKE '%1L%' OR PACKAGE LIKE '%1 Liter%' THEN 1000&#xA;        WHEN PACKAGE LIKE '%670%' THEN 670&#xA;        WHEN PACKAGE LIKE '%500%' THEN 500&#xA;        WHEN PACKAGE LIKE '%330%' THEN 330&#xA;        ELSE 0&#xA;    END as packageSizeMl,&#xA;    CASE &#xA;        WHEN PACKAGE LIKE '%2 litro%' OR PACKAGE LIKE '%2L%' OR PACKAGE LIKE '%2 Liter%' THEN 2.0&#xA;        WHEN PACKAGE LIKE '%1 litro%' OR PACKAGE LIKE '%1L%' OR PACKAGE LIKE '%1 Liter%' THEN 1.0&#xA;        WHEN PACKAGE LIKE '%670%' THEN 0.67&#xA;        WHEN PACKAGE LIKE '%500%' THEN 0.5&#xA;        WHEN PACKAGE LIKE '%330%' THEN 0.33&#xA;        ELSE 0&#xA;    END as packageSizeLiters,&#xA;    CASE WHEN UPPER(DETAIL) LIKE '%DIET%' OR UPPER(DETAIL) LIKE '%LIGHT%' OR UPPER(DETAIL) LIKE '%ZERO%' THEN 1 ELSE 0 END as isDiet,&#xA;    CASE WHEN UPPER(PACKAGE) LIKE '%LATA%' OR UPPER(PACKAGE) LIKE '%CAN%' THEN 1 ELSE 0 END as isCan,&#xA;    CASE &#xA;        WHEN UPPER(PACKAGE) LIKE '%BOTELLA%' OR UPPER(PACKAGE) LIKE '%BOTTLE%' THEN 1&#xA;        WHEN PACKAGE LIKE '%1 Liter%' OR PACKAGE LIKE '%2 Liter%' THEN 1&#xA;        ELSE 0 &#xA;    END as isBottle&#xA;FROM bd_staging_2025_G01.dbo.stg_Products_G01" xmlns:SQLTask="www.microsoft.com/sqlserver/dts/tasks/sqltask" />
      </DTS:ObjectData>
    </DTS:Executable>

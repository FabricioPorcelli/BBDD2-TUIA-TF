      DTS:ThreadHint="0">
      <DTS:Variables />
      <DTS:ObjectData>
        <SQLTask:SqlTaskData
          SQLTask:Connection="{858D9F11-8E26-4CF7-B138-B5E6CF665B2A}"
          SQLTask:SqlStatementSource="INSERT INTO int_Customers_G01 (CUSTOMER_ID, FULL_NAME, BIRTH_DATE, CITY, STATE, ZIPCODE, CUSTOMER_TYPE)&#xA;SELECT &#xA;    CUSTOMER_ID, &#xA;    FULL_NAME, &#xA;    TRY_CONVERT(DATE, REPLACE(BIRTH_DATE, '&amp;#47;', '/'), 101) as BIRTH_DATE,&#xA;    CITY, &#xA;    STATE, &#xA;    ZIPCODE, &#xA;    'Retail' as CUSTOMER_TYPE&#xA;FROM bd_staging_2025_G01.dbo.stg_CustomerR_G01&#xA;&#xA;UNION ALL&#xA;&#xA;SELECT &#xA;    CUSTOMER_ID, &#xA;    FULL_NAME, &#xA;    TRY_CONVERT(DATE, REPLACE(BIRTH_DATE, '&amp;#47;', '/'), 101) as BIRTH_DATE,&#xA;    CITY, &#xA;    STATE, &#xA;    ZIPCODE, &#xA;    'Wholesale' as CUSTOMER_TYPE&#xA;FROM bd_staging_2025_G01.dbo.stg_CustomerW_G01" xmlns:SQLTask="www.microsoft.com/sqlserver/dts/tasks/sqltask" />
      </DTS:ObjectData>
    </DTS:Executable>

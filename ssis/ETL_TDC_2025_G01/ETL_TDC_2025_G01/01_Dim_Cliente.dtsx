      <DTS:ObjectData>
        <SQLTask:SqlTaskData
          SQLTask:Connection="{88AA68A0-7729-401F-B4E7-6B547E71C12D}"
          SQLTask:SqlStatementSource="INSERT INTO Dim_Cliente_G01 (customerId, fullName, birthDate, customerType, city, state, zipcode)&#xA;SELECT &#xA;    CUSTOMER_ID as customerId,&#xA;    FULL_NAME as fullName,&#xA;    BIRTH_DATE as birthDate,&#xA;    CUSTOMER_TYPE as customerType,&#xA;    CITY as city,&#xA;    STATE as state,&#xA;    ZIPCODE as zipcode&#xA;FROM bd_intermedia_2025_G01.dbo.int_Customers_G01&#xA;" xmlns:SQLTask="www.microsoft.com/sqlserver/dts/tasks/sqltask" />
      </DTS:ObjectData>
    </DTS:Executable>
    <DTS:Executable
      DTS:refId="Package\Load Customer in Sales DATAWAREHOUSE"
      DTS:CreationName="Microsoft.ExecuteSQLTask"
      DTS:Description="Execute SQL Task"
      DTS:DTSID="{F81AD14B-BF68-4762-8945-8A855FA403C7}"
      DTS:ExecutableType="Microsoft.ExecuteSQLTask"
      DTS:LocaleID="-1"
      DTS:ObjectName="Load Customer in Sales DATAWAREHOUSE"
      DTS:TaskContact="Execute SQL Task; Microsoft Corporation; SQL Server 2025; © 2025 Microsoft Corporation; All Rights Reserved;http://www.microsoft.com/sql/support/default.asp;1"
      DTS:ThreadHint="0">
      <DTS:Variables />
      <DTS:ObjectData>
        <SQLTask:SqlTaskData
          SQLTask:Connection="{88AA68A0-7729-401F-B4E7-6B547E71C12D}"
          SQLTask:SqlStatementSource="INSERT INTO Dim_Cliente_G01 &#xA;(customerId, fullName, birthDate, customerType, city, state, zipcode)&#xA;SELECT DISTINCT&#xA;    s.CUSTOMER_ID        AS customerId,&#xA;    'Cliente Desconocido' AS fullName,&#xA;    NULL                 AS birthDate,&#xA;    'Unknown'            AS customerType,&#xA;    'N/A'                AS city,&#xA;    'N/A'                AS state,&#xA;    'UNKNOWN'            AS zipcode&#xA;FROM (&#xA;    SELECT DISTINCT CUSTOMER_ID &#xA;    FROM bd_staging_2025_G01.dbo.stg_BillingHistory_G01&#xA;    UNION&#xA;    SELECT DISTINCT CUSTOMER_ID &#xA;    FROM bd_staging_2025_G01.dbo.stg_Billing_G01&#xA;) s&#xA;WHERE NOT EXISTS (&#xA;    SELECT 1 &#xA;    FROM Dim_Cliente_G01 dc &#xA;    WHERE dc.customerId = s.CUSTOMER_ID&#xA;)" xmlns:SQLTask="www.microsoft.com/sqlserver/dts/tasks/sqltask" />
      </DTS:ObjectData>
    </DTS:Executable>
    <DTS:Executable
      DTS:refId="Package\Load Customer INTERMEDIATE"
      DTS:CreationName="Microsoft.ExecuteSQLTask"

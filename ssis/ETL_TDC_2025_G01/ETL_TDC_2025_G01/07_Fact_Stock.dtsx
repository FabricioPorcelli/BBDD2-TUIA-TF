      DTS:DTSID="{e885f1b0-6fe3-41fe-adcb-8266c286e7f2}"
      DTS:ExecutableType="Microsoft.ExecuteSQLTask"
      DTS:LocaleID="-1"
      DTS:ObjectName="Load Stock DATAWAREHOUSE"
      DTS:TaskContact="Execute SQL Task; Microsoft Corporation; SQL Server 2025; © 2025 Microsoft Corporation; All Rights Reserved;http://www.microsoft.com/sql/support/default.asp;1"
      DTS:ThreadHint="0">
      <DTS:Variables />
      <DTS:ObjectData>
        <SQLTask:SqlTaskData
          SQLTask:Connection="{88AA68A0-7729-401F-B4E7-6B547E71C12D}"
          SQLTask:SqlStatementSource="INSERT INTO Fact_Stock_G01 (dateKey, productKey, variation, stockBalance)&#xA;SELECT &#xA;    CAST(FORMAT(TRY_CONVERT(DATE, SUBSTRING(s.DATE, 1, 10), 101), 'yyyyMMdd') AS INT) as dateKey,&#xA;    dp.productKey,&#xA;    CAST(s.VARIATION AS DECIMAL(10,2)) as variation,&#xA;    SUM(CAST(s.VARIATION AS DECIMAL(10,2))) OVER (&#xA;        PARTITION BY s.PRODUCT_ID &#xA;        ORDER BY TRY_CONVERT(DATE, SUBSTRING(s.DATE, 1, 10), 101)&#xA;        ROWS UNBOUNDED PRECEDING&#xA;    ) as stockBalance&#xA;FROM bd_staging_2025_G01.dbo.stg_Stock_G01 s&#xA;INNER JOIN Dim_Producto_G01 dp ON dp.productId = s.PRODUCT_ID&#xA;WHERE TRY_CONVERT(DATE, SUBSTRING(s.DATE, 1, 10), 101) IS NOT NULL&#xA;  AND s.PRODUCT_ID IS NOT NULL&#xA;ORDER BY TRY_CONVERT(DATE, SUBSTRING(s.DATE, 1, 10), 101), s.PRODUCT_ID" xmlns:SQLTask="www.microsoft.com/sqlserver/dts/tasks/sqltask" />
      </DTS:ObjectData>
    </DTS:Executable>

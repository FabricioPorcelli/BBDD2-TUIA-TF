      <DTS:ObjectData>
        <SQLTask:SqlTaskData
          SQLTask:Connection="{88AA68A0-7729-401F-B4E7-6B547E71C12D}"
          SQLTask:SqlStatementSource="-- Insertar empleado faltante&#xA;INSERT INTO Dim_Empleado_G01 (employeeId, fullName, gender, category, employmentDate, birthDate, age, ageRangeKey, educationLevel, yearsEmployed, seniorityGroup)&#xA;SELECT DISTINCT&#xA;    s.EMPLOYEE_ID as employeeId,&#xA;    'Empleado Desconocido' as fullName,&#xA;    'U' as gender,&#xA;    'Unknown' as category,&#xA;    NULL as employmentDate,&#xA;    NULL as birthDate,&#xA;    0 as age,&#xA;    NULL as ageRangeKey,&#xA;    'Unknown' as educationLevel,&#xA;    0 as yearsEmployed,&#xA;    0 as seniorityGroup&#xA;FROM (&#xA;    SELECT DISTINCT EMPLOYEE_ID &#xA;    FROM bd_staging_2025_G01.dbo.stg_BillingHistory_G01&#xA;    UNION&#xA;    SELECT DISTINCT EMPLOYEE_ID &#xA;    FROM bd_staging_2025_G01.dbo.stg_Billing_G01&#xA;) s&#xA;WHERE NOT EXISTS (&#xA;    SELECT 1 &#xA;    FROM Dim_Empleado_G01 de &#xA;    WHERE de.employeeId = s.EMPLOYEE_ID&#xA;)" xmlns:SQLTask="www.microsoft.com/sqlserver/dts/tasks/sqltask" />
      </DTS:ObjectData>
    </DTS:Executable>

    <DTS:Executable
      DTS:refId="Package\Load Employee DATAWAREHOUSE"
      DTS:CreationName="Microsoft.ExecuteSQLTask"
      DTS:Description="Execute SQL Task"
      DTS:DTSID="{6aa41d65-405a-4e88-949f-3f047783c946}"
      DTS:ExecutableType="Microsoft.ExecuteSQLTask"
      DTS:LocaleID="-1"
      DTS:ObjectName="Load Employee DATAWAREHOUSE"
      DTS:TaskContact="Execute SQL Task; Microsoft Corporation; SQL Server 2025; © 2025 Microsoft Corporation; All Rights Reserved;http://www.microsoft.com/sql/support/default.asp;1"
      DTS:ThreadHint="0">
      <DTS:Variables />
      <DTS:ObjectData>
        <SQLTask:SqlTaskData
          SQLTask:Connection="{88AA68A0-7729-401F-B4E7-6B547E71C12D}"
          SQLTask:SqlStatementSource="INSERT INTO Dim_Empleado_G01 (employeeId, fullName, gender, category, employmentDate, birthDate, age, ageRangeKey, educationLevel, yearsEmployed, seniorityGroup)&#xA;SELECT &#xA;    EMPLOYEE_ID as employeeId,&#xA;    FULL_NAME as fullName,&#xA;    GENDER as gender,&#xA;    CATEGORY as category,&#xA;    TRY_CONVERT(DATE, EMPLOYMENT_DATE) as employmentDate,&#xA;    TRY_CONVERT(DATE, BIRTH_DATE) as birthDate,&#xA;    DATEDIFF(YEAR, TRY_CONVERT(DATE, BIRTH_DATE), GETDATE()) as age,&#xA;    (&#xA;        SELECT TOP 1 ar.ageRangeKey&#xA;        FROM Dim_RangoEtario_G01 ar&#xA;        WHERE DATEDIFF(YEAR, TRY_CONVERT(DATE, BIRTH_DATE), GETDATE()) BETWEEN ar.minAge AND ar.maxAge&#xA;    ) as ageRangeKey,&#xA;    EDUCATION_LEVEL as educationLevel,&#xA;    DATEDIFF(YEAR, TRY_CONVERT(DATE, EMPLOYMENT_DATE), GETDATE()) as yearsEmployed,&#xA;    CASE &#xA;        WHEN DATEDIFF(YEAR, TRY_CONVERT(DATE, EMPLOYMENT_DATE), GETDATE()) &lt; 1 THEN 1&#xA;        WHEN DATEDIFF(YEAR, TRY_CONVERT(DATE, EMPLOYMENT_DATE), GETDATE()) BETWEEN 1 AND 2 THEN 2&#xA;        WHEN DATEDIFF(YEAR, TRY_CONVERT(DATE, EMPLOYMENT_DATE), GETDATE()) BETWEEN 3 AND 5 THEN 3&#xA;        ELSE 4&#xA;    END as seniorityGroup&#xA;FROM bd_staging_2025_G01.dbo.stg_Employee_G01&#xA;WHERE TRY_CONVERT(DATE, BIRTH_DATE) IS NOT NULL" xmlns:SQLTask="www.microsoft.com/sqlserver/dts/tasks/sqltask" />
      </DTS:ObjectData>
    </DTS:Executable>

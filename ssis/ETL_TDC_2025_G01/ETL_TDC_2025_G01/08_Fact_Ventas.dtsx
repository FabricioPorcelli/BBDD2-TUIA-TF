    <DTS:Executable
      DTS:refId="Package\Load Sales DATAWAREHOUSE"
      DTS:CreationName="Microsoft.ExecuteSQLTask"
      DTS:Description="Execute SQL Task"
      DTS:DTSID="{e0692a0d-c40d-4f4f-b7a3-34bd1a9efcae}"
      DTS:ExecutableType="Microsoft.ExecuteSQLTask"
      DTS:LocaleID="-1"
      DTS:ObjectName="Load Sales DATAWAREHOUSE"
      DTS:TaskContact="Execute SQL Task; Microsoft Corporation; SQL Server 2025; © 2025 Microsoft Corporation; All Rights Reserved;http://www.microsoft.com/sql/support/default.asp;1"
      DTS:ThreadHint="0">
      <DTS:Variables />
      <DTS:ObjectData>
        <SQLTask:SqlTaskData
          SQLTask:Connection="{88AA68A0-7729-401F-B4E7-6B547E71C12D}"
          SQLTask:SqlStatementSource="WITH PricesValid AS (&#xA;    SELECT DISTINCT&#xA;        s.BILLING_ID,&#xA;        s.PRODUCT_ID,&#xA;        s.DATE,&#xA;        ISNULL(&#xA;            -- Precio vigente: el más reciente anterior o igual a la fecha de venta&#xA;            (&#xA;                SELECT TOP 1 p.PRICE&#xA;                FROM bd_staging_2025_G01.dbo.stg_Prices_G01 p&#xA;                WHERE p.PRODUCT_ID = s.PRODUCT_ID&#xA;                  AND TRY_CONVERT(DATETIME, p.DATE) &lt;= s.DATE&#xA;                ORDER BY TRY_CONVERT(DATETIME, p.DATE) DESC&#xA;            ),&#xA;            -- Fallback: el precio más antiguo disponible para ese producto&#xA;            (&#xA;                SELECT TOP 1 p.PRICE&#xA;                FROM bd_staging_2025_G01.dbo.stg_Prices_G01 p&#xA;                WHERE p.PRODUCT_ID = s.PRODUCT_ID&#xA;                ORDER BY TRY_CONVERT(DATETIME, p.DATE) ASC&#xA;            )&#xA;        ) AS unitPrice&#xA;    FROM bd_intermedia_2025_G01.dbo.int_SalesUnified_G01 s&#xA;),&#xA;BillingTotals AS (&#xA;    SELECT &#xA;        s.BILLING_ID,&#xA;        s.DATE,&#xA;        SUM(s.QUANTITY * pv.unitPrice) AS totalBilling&#xA;    FROM bd_intermedia_2025_G01.dbo.int_SalesUnified_G01 s&#xA;    INNER JOIN PricesValid pv &#xA;        ON pv.BILLING_ID = s.BILLING_ID &#xA;       AND pv.PRODUCT_ID = s.PRODUCT_ID&#xA;    GROUP BY s.BILLING_ID, s.DATE&#xA;),&#xA;ApplicableDiscounts AS (&#xA;    SELECT &#xA;        bt.BILLING_ID,&#xA;        ISNULL(MAX(d.PERCENTAGE), 0) AS discountPercentage&#xA;    FROM BillingTotals bt&#xA;    LEFT JOIN bd_staging_2025_G01.dbo.stg_Discounts_G01 d &#xA;        ON bt.totalBilling &gt;= d.TOTAL_BILLING&#xA;       AND bt.DATE BETWEEN TRY_CONVERT(DATE, d.[FROM]) &#xA;                       AND TRY_CONVERT(DATE, d.UNTIL)&#xA;    GROUP BY bt.BILLING_ID&#xA;),&#xA;SalesData AS (&#xA;    SELECT &#xA;        s.BILLING_ID,&#xA;        s.DATE,&#xA;        s.CUSTOMER_ID,&#xA;        s.EMPLOYEE_ID,&#xA;        s.PRODUCT_ID,&#xA;        s.QUANTITY,&#xA;        pv.unitPrice,&#xA;        ad.discountPercentage,&#xA;        ROW_NUMBER() OVER (&#xA;            PARTITION BY s.BILLING_ID, s.PRODUCT_ID &#xA;            ORDER BY s.DATE&#xA;        ) AS rn&#xA;    FROM bd_intermedia_2025_G01.dbo.int_SalesUnified_G01 s&#xA;    INNER JOIN PricesValid pv &#xA;        ON pv.BILLING_ID = s.BILLING_ID &#xA;       AND pv.PRODUCT_ID = s.PRODUCT_ID&#xA;    LEFT JOIN ApplicableDiscounts ad &#xA;        ON ad.BILLING_ID = s.BILLING_ID&#xA;    WHERE pv.unitPrice IS NOT NULL &#xA;      AND pv.unitPrice &gt; 0&#xA;)&#xA;&#xA;INSERT INTO datawarehouse_2025_G01.dbo.Fact_Ventas_G01&#xA;(&#xA;    billingKey,&#xA;    dateKey,&#xA;    customerKey,&#xA;    productKey,&#xA;    employeeKey,&#xA;    regionKey,&#xA;    customerAgeRangeKey,&#xA;    employeeYearsEmployedAtSale,&#xA;    employeeAgeAtSale,&#xA;    quantity,&#xA;    liters,&#xA;    unitPrice,&#xA;    grossAmount,&#xA;    discountPercentage,&#xA;    discountAmount,&#xA;    netAmount&#xA;)&#xA;SELECT &#xA;    ROW_NUMBER() OVER (ORDER BY sd.BILLING_ID, sd.PRODUCT_ID) AS billingKey,&#xA;    CAST(FORMAT(sd.DATE, 'yyyyMMdd') AS INT) AS dateKey,&#xA;    dc.customerKey,&#xA;    dp.productKey,&#xA;    de.employeeKey,&#xA;    dr.regionKey,&#xA;&#xA;    -- rango etario del cliente al momento de la venta&#xA;    ar.ageRangeKey AS customerAgeRangeKey,&#xA;&#xA;    -- antigüedad del empleado al momento de la venta&#xA;    DATEDIFF(YEAR, de.employmentDate, sd.DATE) &#xA;        AS employeeYearsEmployedAtSale,&#xA;&#xA;    DATEDIFF(YEAR, de.birthDate, sd.DATE) &#xA;        AS employeeAgeAtSale,&#xA;&#xA;    sd.QUANTITY AS quantity,&#xA;    sd.QUANTITY * dp.packageSizeLiters AS liters,&#xA;    sd.unitPrice,&#xA;    sd.QUANTITY * sd.unitPrice AS grossAmount,&#xA;    sd.discountPercentage,&#xA;    (sd.QUANTITY * sd.unitPrice) * (sd.discountPercentage / 100.0) AS discountAmount,&#xA;    (sd.QUANTITY * sd.unitPrice) * (1 - sd.discountPercentage / 100.0) AS netAmount&#xA;FROM SalesData sd&#xA;INNER JOIN datawarehouse_2025_G01.dbo.Dim_Producto_G01 dp &#xA;    ON dp.productId = sd.PRODUCT_ID&#xA;INNER JOIN datawarehouse_2025_G01.dbo.Dim_Cliente_G01 dc &#xA;    ON dc.customerId = sd.CUSTOMER_ID&#xA;INNER JOIN datawarehouse_2025_G01.dbo.Dim_Empleado_G01 de &#xA;    ON de.employeeId = sd.EMPLOYEE_ID&#xA;LEFT JOIN datawarehouse_2025_G01.dbo.Dim_Region_G01 dr &#xA;    ON dr.zipcode = dc.zipcode&#xA;LEFT JOIN datawarehouse_2025_G01.dbo.Dim_RangoEtario_G01 ar&#xA;    ON dc.birthDate IS NOT NULL&#xA;   AND DATEDIFF(YEAR, dc.birthDate, sd.DATE)&#xA;       BETWEEN ar.minAge AND ar.maxAge&#xA;WHERE sd.rn = 1" xmlns:SQLTask="www.microsoft.com/sqlserver/dts/tasks/sqltask" />
      </DTS:ObjectData>
    </DTS:Executable>
    <DTS:Executable
      DTS:refId="Package\Load Sales INTERMEDIATE"
      DTS:CreationName="Microsoft.ExecuteSQLTask"
      DTS:Description="Execute SQL Task"
      DTS:DTSID="{c88239b0-db27-45bc-831d-ce387ac382da}"
      DTS:ExecutableType="Microsoft.ExecuteSQLTask"
      DTS:LocaleID="-1"
      DTS:ObjectName="Load Sales INTERMEDIATE"
      DTS:TaskContact="Execute SQL Task; Microsoft Corporation; SQL Server 2025; © 2025 Microsoft Corporation; All Rights Reserved;http://www.microsoft.com/sql/support/default.asp;1"
      DTS:ThreadHint="0">
      <DTS:Variables />
      <DTS:ObjectData>
        <SQLTask:SqlTaskData
          SQLTask:Connection="{858D9F11-8E26-4CF7-B138-B5E6CF665B2A}"
          SQLTask:SqlStatementSource="INSERT INTO int_SalesUnified_G01 (BILLING_ID, DATE, CUSTOMER_ID, EMPLOYEE_ID, PRODUCT_ID, QUANTITY, SOURCE)&#xA;-- Ventas históricas&#xA;SELECT &#xA;    BILLING_ID, &#xA;    TRY_CONVERT(DATE, DATE) as DATE,&#xA;    CUSTOMER_ID, &#xA;    EMPLOYEE_ID, &#xA;    PRODUCT_ID, &#xA;    QUANTITY, &#xA;    'HISTORY' as SOURCE&#xA;FROM bd_staging_2025_G01.dbo.stg_BillingHistory_G01&#xA;WHERE TRY_CONVERT(DATE, DATE) IS NOT NULL&#xA;&#xA;UNION ALL&#xA;&#xA;-- Ventas actuales&#xA;SELECT &#xA;    b.BILLING_ID, &#xA;    TRY_CONVERT(DATE, b.DATE) as DATE,&#xA;    b.CUSTOMER_ID, &#xA;    b.EMPLOYEE_ID, &#xA;    bd.PRODUCT_ID, &#xA;    bd.QUANTITY, &#xA;    'CURRENT' as SOURCE&#xA;FROM bd_staging_2025_G01.dbo.stg_Billing_G01 b&#xA;INNER JOIN bd_staging_2025_G01.dbo.stg_BillingDetail_G01 bd ON b.BILLING_ID = bd.BILLING_ID&#xA;WHERE TRY_CONVERT(DATE, b.DATE) IS NOT NULL" xmlns:SQLTask="www.microsoft.com/sqlserver/dts/tasks/sqltask" />
      </DTS:ObjectData>
    </DTS:Executable>

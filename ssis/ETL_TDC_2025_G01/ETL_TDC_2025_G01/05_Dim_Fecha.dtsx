      <DTS:Variables />
      <DTS:ObjectData>
        <SQLTask:SqlTaskData
          SQLTask:Connection="{88AA68A0-7729-401F-B4E7-6B547E71C12D}"
          SQLTask:SqlStatementSource="DELETE FROM Dim_Fecha_G01;" xmlns:SQLTask="www.microsoft.com/sqlserver/dts/tasks/sqltask" />
      </DTS:ObjectData>
    </DTS:Executable>
    <DTS:Executable
      DTS:refId="Package\Load Dates DATAWAREHOUSE"
      DTS:CreationName="Microsoft.ExecuteSQLTask"
      DTS:Description="Execute SQL Task"
      DTS:DTSID="{c76b55dc-33b6-4860-a9c4-89acce369626}"
      DTS:ExecutableType="Microsoft.ExecuteSQLTask"
      DTS:LocaleID="-1"
      DTS:ObjectName="Load Dates DATAWAREHOUSE"
      DTS:TaskContact="Execute SQL Task; Microsoft Corporation; SQL Server 2025; © 2025 Microsoft Corporation; All Rights Reserved;http://www.microsoft.com/sql/support/default.asp;1"
      DTS:ThreadHint="0">
      <DTS:Variables />
      <DTS:ObjectData>
        <SQLTask:SqlTaskData
          SQLTask:Connection="{88AA68A0-7729-401F-B4E7-6B547E71C12D}"
          SQLTask:SqlStatementSource="DECLARE @StartDate DATE = '2000-01-01'&#xA;&#xA;DECLARE @EndDate DATE = '2025-12-31'&#xA;&#xA;WHILE @StartDate &lt;= @EndDate&#xA;BEGIN&#xA;    IF NOT EXISTS (SELECT 1 FROM Dim_Fecha_G01 WHERE fullDate = @StartDate)&#xA;    BEGIN&#xA;        INSERT INTO Dim_Fecha_G01 (dateKey, fullDate, day, month, quarter, year, dayOfWeek, dayName, monthName, isHoliday, holidayName, weekOfYear, semester)&#xA;        SELECT &#xA;            CAST(FORMAT(@StartDate, 'yyyyMMdd') AS INT) as dateKey,&#xA;            @StartDate as fullDate,&#xA;            DAY(@StartDate) as day,&#xA;            MONTH(@StartDate) as month,&#xA;            DATEPART(QUARTER, @StartDate) as quarter,&#xA;            YEAR(@StartDate) as year,&#xA;            DATEPART(WEEKDAY, @StartDate) as dayOfWeek,&#xA;            DATENAME(WEEKDAY, @StartDate) as dayName,&#xA;            DATENAME(MONTH, @StartDate) as monthName,&#xA;            CASE WHEN h.HOLIDAY IS NOT NULL THEN 1 ELSE 0 END as isHoliday,&#xA;            h.HOLIDAY as holidayName,&#xA;            DATEPART(WEEK, @StartDate) as weekOfYear,&#xA;            CASE WHEN MONTH(@StartDate) &lt;= 6 THEN 1 ELSE 2 END as semester&#xA;        FROM (SELECT @StartDate as dt) d&#xA;        LEFT JOIN bd_staging_2025_G01.dbo.stg_Holidays_G01 h ON TRY_CONVERT(DATE, h.DATE) = @StartDate&#xA;    END&#xA;    &#xA;    SET @StartDate = DATEADD(DAY, 1, @StartDate)&#xA;END" xmlns:SQLTask="www.microsoft.com/sqlserver/dts/tasks/sqltask" />
      </DTS:ObjectData>
    </DTS:Executable>
